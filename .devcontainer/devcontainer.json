{
  "name": "Python 3",
  "image": "mcr.microsoft.com/devcontainers/python:1-3.11-bullseye",
  "customizations": {
    "codespaces": {
      "openFiles": [
        "README.md",
        "main.py"
      ]
    },
    "vscode": {
      "settings": {},
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance"
      ]
    }
  },
  "updateContentCommand": "[ -f packages.txt ] && sudo apt update && sudo apt upgrade -y && sudo xargs apt install -y <packages.txt; [ -f requirements.txt ] && pip3 install --user -r requirements.txt; pip3 install --user apache-airflow streamlit; echo '✅ Packages installed and Requirements met'",
  "postAttachCommand": "streamlit run main.py --server.enableCORS false --server.enableXsrfProtection false",
  "portsAttributes": {
    "8501": {
      "label": "Streamlit Application",
      "onAutoForward": "openPreview"
    },
    "8080": {
      "label": "Airflow Web UI",
      "onAutoForward": "openPreview"
    },
    "5000": {
      "label": "Flask API",
      "onAutoForward": "openPreview"
    }
  },
  "forwardPorts": [
    8501,
    8080,
    5000
  ]
}
